{
  "name": "nighttable-co",
  "private": true,
  "description": "Food & Nightlife premium marketplace + venue SaaS for Colombia",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:studio": "turbo db:studio",
    "db:seed": "npm run db:seed -w @saas/db",
    "db:seed:prod": "node scripts/seed-prod.mjs",
    "make-superadmin": "node scripts/make-superadmin.mjs",
    "test:e2e": "npm test -w @saas/e2e",
    "test:unit": "npm test -w @saas/domain && npm test -w @saas/contracts && npm test -w @saas/api && npm test -w @saas/db",
    "mobile:www": "npm run build:www -w @saas/mobile",
    "mobile:sync": "npm run cap:sync -w @saas/mobile",
    "check:prod-env": "node scripts/check-prod-env.mjs",
    "release": "node scripts/release.mjs",
    "gen:secrets": "node scripts/gen-secrets.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs"
  },




  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  }
}

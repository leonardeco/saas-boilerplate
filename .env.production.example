# =============================================================================
# NightTable CO — PRODUCTION environment template
# =============================================================================
# 1. Copy to your host secrets manager / Render / Railway dashboard
# 2. NEVER commit a real .env.production
# 3. Validate:  set -a; source .env.production; set +a; npm run check:prod-env
#
# Generate secrets:
#   openssl rand -base64 48
# =============================================================================

# ─── Runtime (required) ─────────────────────────────────────────────────────
NODE_ENV=production
REGION=sao
# Behind reverse proxy / PaaS load balancer
TRUST_PROXY=true

# ─── Database (required) ────────────────────────────────────────────────────
# Primary writer — Neon / RDS / Render / Railway Postgres 16
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/nighttable_db?sslmode=require
# Optional read replica for catalog + geo (same DB if omitted)
DATABASE_READ_URL=

# ─── Redis (required for multi-instance booking locks + worker queues) ──────
REDIS_URL=redis://default:PASSWORD@HOST:6379

# ─── JWT (required — must be unique & strong) ───────────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_openssl_rand_base64_48
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_openssl_rand_base64_48
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Public URLs (required — https only in production) ──────────────────────
# Web app (users)
WEB_URL=https://app.tudominio.com
# Browser CORS (comma-separated if several frontends)
CORS_ORIGIN=https://app.tudominio.com
# API public base (OAuth redirects, webhooks docs)
API_PUBLIC_URL=https://api.tudominio.com
# Next.js build-time public API (must match API_PUBLIC_URL)
NEXT_PUBLIC_API_URL=https://api.tudominio.com
NEXT_PUBLIC_APP_NAME=NightTable CO

# ─── HTTP server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
# Render/Railway often inject PORT — API also reads PORT via API_PORT default
API_PORT=3001
COOKIE_SECURE=true
# Leave unset/false in prod (Swagger off). Set true only if docs are private.
# ENABLE_SWAGGER=false

# ─── Search (recommended) ───────────────────────────────────────────────────
MEILI_HOST=https://meili.tudominio.com
MEILI_MASTER_KEY=REPLACE_STRONG_MEILI_KEY

# ─── Stripe (venue SaaS billing) ────────────────────────────────────────────
# Use sk_live_ / pk_live_ for production money
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
# Webhook endpoint to register in Stripe:
#   POST {API_PUBLIC_URL}/billing/webhook

# ─── Email (recommended for booking notifications) ──────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=no-reply@tudominio.com

# ─── OAuth (optional but recommended) ───────────────────────────────────────
# Google Cloud Console → OAuth client → Authorized redirect URI:
#   {API_PUBLIC_URL}/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth App → Authorization callback URL:
#   {API_PUBLIC_URL}/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Catalog ingestion (optional) ───────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
FOURSQUARE_API_KEY=

# ─── Maps (optional frontend) ───────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── WhatsApp Meta Cloud API (optional) ─────────────────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_USE_TEMPLATES=true
WHATSAPP_TEMPLATE_LANG=es
WHATSAPP_TEMPLATE_HOLD=nt_booking_hold
WHATSAPP_TEMPLATE_CONFIRMED=nt_booking_confirmed
WHATSAPP_TEMPLATE_CANCELLED=nt_booking_cancelled

# ─── Observability (optional) ───────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector:4318
OTEL_SERVICE_NAME=nighttable-api
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer xxx

# ─── Feature flags (app-level defaults; admin flags in DB override UX) ──────
FEATURE_PREMIUM_ONLY_DEFAULT=true
FEATURE_BOOKING_ENABLED=true

# ─── Capacitor / mobile (build-time / local only; not required on API) ──────
# CAPACITOR_SERVER_URL=https://app.tudominio.com

# =============================================================================
# After deploy checklist (quick)
# =============================================================================
# 1. npm run check:prod-env
# 2. npm run db:migrate -w @saas/db
# 3. npm run db:seed -w @saas/db          # geo + plans (review demo venues!)
# 4. npm run make-superadmin -- ops@tudominio.com
# 5. Smoke: /health /ready /geo/cities login booking
# 6. Stripe webhook + OAuth redirects + DNS TLS
# Full list: docs/runbooks/release-checklist.md
# =============================================================================

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nighttable_db
# Optional read replica for catalog/geo (falls back to primary)
DATABASE_READ_URL=

# ─── Redis (holds, queues, rate limit) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Search ─────────────────────────────────────────────────────
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key-change-me

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── API ────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ─── Web ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=NightTable CO
WEB_URL=http://localhost:3000

# ─── Stripe (venue SaaS plans) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ─── Email ──────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=no-reply@example.com

# ─── Catalog providers (D5 ingestion) ───────────────────────────
# Leave empty in local to use mock/OSM-only adapters
GOOGLE_PLACES_API_KEY=
FOURSQUARE_API_KEY=

# ─── Maps (frontend) ────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Feature flags ──────────────────────────────────────────────
FEATURE_PREMIUM_ONLY_DEFAULT=true
FEATURE_BOOKING_ENABLED=true

# ─── Cookies ────────────────────────────────────────────────────
# true in production (HTTPS)
COOKIE_SECURE=false

# ─── WhatsApp (Meta Cloud API, optional) ───────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_USE_TEMPLATES=false
WHATSAPP_TEMPLATE_LANG=es
WHATSAPP_TEMPLATE_HOLD=nt_booking_hold
WHATSAPP_TEMPLATE_CONFIRMED=nt_booking_confirmed
WHATSAPP_TEMPLATE_CANCELLED=nt_booking_cancelled

# ─── OAuth ──────────────────────────────────────────────────────
# API_PUBLIC_URL used as OAuth redirect base (multi-region: global API host)
API_PUBLIC_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# redirect: {API_PUBLIC_URL}/auth/oauth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# redirect: {API_PUBLIC_URL}/auth/oauth/github/callback

# ─── Region / observability ─────────────────────────────────────
REGION=local
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nighttable-api
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer xxx



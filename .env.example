# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_db

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── API ────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ─── Web ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Plans (Stripe Price IDs) ────────────────────────────────────
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ─── Email ───────────────────────────────────────────────────────
# Opcion 1: Resend (recomendado para produccion) → https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=no-reply@tudominio.com

# Opcion 2: SMTP personalizado
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=tu-app-password

# Si ninguna esta configurada, en desarrollo se usa Ethereal automaticamente
# (sin config) y se muestra la URL de preview en consola.

# ─── OAuth — Google ──────────────────────────────────────────────
# https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth — GitHub ──────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── URLs ────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
